# Public hostname the feed generator is served from (behind HTTPS)
FEEDGEN_HOSTNAME=feed.example.com

# DID of the account that publishes/owns the feed record (set after running npm run publish-feed)
FEEDGEN_PUBLISHER_DID=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx

# Record key of the feed generator record
FEED_RKEY=the-algorithm

PORT=3000
DB_PATH=./data/rewind.db
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
RETENTION_HOURS=48

# Only needed for scripts/publish.ts
# BLUESKY_HANDLE=you.bsky.social
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
